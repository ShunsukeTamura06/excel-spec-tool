# Nuxt フロントエンドの環境変数テンプレート.
# このファイルを .env としてコピーし、必要に応じて値を変更する:
#   cp .env.example .env
#
# .env は .gitignore で除外している.

# フロントが叩く Backend のベース URL.
# パス分離デプロイでは本番 `/api`、開発 `/dev/api` を指定する.
NUXT_PUBLIC_BACKEND_URL=/api

# Frontend の配信ベースパス.
# パス分離デプロイの開発系では `/dev/` を指定する.
# NUXT_APP_BASE_URL=/

# Nuxt dev サーバの待受ポート.
# NUXT_PORT=3001

# Nuxt 起動時のテレメトリ送信を停止 (閉鎖網推奨).
# NUXT_TELEMETRY_DISABLED=1
